# Copy this file's contents into Render's Environment Variables section — don't commit a real .env file.

# Get this from console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Get these from twilio.com/console (Account Info section)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio WhatsApp sender, in this exact format (sandbox number shown as example)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
